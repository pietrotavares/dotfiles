[submodule "meta/dotbot"]
	path = meta/dotbot
	url = https://github.com/anishathalye/dotbot
    	branch = master
    	ignore = dirty
[submodule "meta/dotbot_plugins/dotbot-apt"]
	path = meta/dotbot_plugins/dotbot-apt
	url = https://github.com/bryant1410/dotbot-apt
[submodule "meta/dotbot_plugins/dotbot-sudo"]
	path = meta/dotbot_plugins/dotbot-sudo
	url = https://github.com/DrDynamic/dotbot-sudo
[submodule "meta/dotbot_plugins/dotbot-git"]
	path = meta/dotbot_plugins/dotbot-git
	url = https://github.com/DrDynamic/dotbot-git.git
[submodule "meta/dotbot_plugins/dotbot-flatpak"]
	path = meta/dotbot_plugins/dotbot-flatpak
	url = https://github.com/DrDynamic/dotbot-flatpak.git
[submodule "meta/dotbot_plugins/dotbot-rust"]
	path = meta/dotbot_plugins/dotbot-rust
	url = https://github.com/alexcormier/dotbot-rust.git
	branch = master
	ignore = dirty
